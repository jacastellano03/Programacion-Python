   "source": [
    "# Ejercicio 13\n",
    "# Escribir un programa que muestre el eco de todo lo que el usuario introduzca hasta que el usuario escriba “salir” que terminará.\n",
    "\n",
    "text = input(\"Escriba algo: \")\n",
    "\n",
    "while text != \"salir\":\n",
    "    print(text)\n",
    "    text = input(\"Escriba algo: \")\n",
    "\n",
    "print(\"Programa finalizado\")"
   ]
