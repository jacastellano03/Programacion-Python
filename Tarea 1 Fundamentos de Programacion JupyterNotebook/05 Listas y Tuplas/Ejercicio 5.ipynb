    "# Ejercicio 5\n",
    "# Escribir un programa que almacene en una lista los números del 1 al 10 y los muestre por pantalla en orden inverso separados por comas.\n",
    "\n",
    "numeros = []\n",
    "\n",
    "for i in range(1, 11):\n",
    "    numeros.append(i)\n",
    "\n",
    "numeros.reverse()\n",
    "\n",
    "print(numeros)"
