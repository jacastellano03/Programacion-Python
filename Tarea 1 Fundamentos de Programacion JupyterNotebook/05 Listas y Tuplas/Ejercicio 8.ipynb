    "# Ejercicio 8\n",
    "# Escribir un programa que pida al usuario una palabra y muestre por pantalla si es un palíndromo.\n",
    "\n",
    "palabra = input(\"Ingrese una palabra: \")\n",
    "\n",
    "if palabra == palabra[::-1]:\n",
    "    print(\"Es un palíndromo\")\n",
    "else:\n",
    "    print(\"No es un palíndromo\")\n",
    "    "
